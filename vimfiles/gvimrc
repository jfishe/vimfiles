" Cross‑platform font selection with auto‑detection {{{
function! SelectBestGuiFont() " {{{
  " Preferred fonts in order (GTK/macOS names)
  let gtk_fonts = [
        \ 'CaskaydiaCove\ Nerd\ Font\ Mono',
        \ 'CaskaydiaCove\ Nerd\ Font',
        \ 'Cascadia\ Code',
        \ 'Cascadia\ Mono',
        \ 'DejaVu\ Sans\ Mono',
        \ 'Consolas'
        \ ]

  " Preferred fonts in order (Windows GDI names)
  let win_fonts = [
        \ 'CaskaydiaCove_NFM',
        \ 'CaskaydiaCove_Nerd_Font_Mono',
        \ 'CaskaydiaCove_Nerd_Font',
        \ 'Cascadia_Code',
        \ 'Cascadia_Mono',
        \ 'Consolas'
        \ ]

  " Platform-specific size and flags
  if has('gui_win32')
    let fonts = win_fonts
    let size = ':h10'
    let flags = ':cANSI:qCLEARTYPE'
  elseif has('gui_gtk3') || has('gui_gtk2') || has('gui_macvim')
    let fonts = gtk_fonts
    let size = '\ 11'
    let flags = ''
  else
    return
  endif

  " Try each font until one succeeds
  for f in fonts
    try
      execute 'set guifont=' .. f .. size .. flags
      if &guifont =~ substitute(f, '\\ ', ' ', 'g')
        return
      endif
    catch
    endtry
  endfor
endfunction " }}}

autocmd GUIEnter * call SelectBestGuiFont()
" }}}

